{
  "$schema": "https://turbo.build/schema.json",
  "ui": "tui",
  "globalEnv": [
    "ALLOWED_EMAILS",
    "AI_GATEWAY_API_KEY",
    "APP_ENCRYPTION_KEY",
    "BETTER_AUTH_SECRET",
    "BETTER_AUTH_URL",
    "CRON_SECRET",
    "DATABASE_URL",
    "DATABASE_URL_DIRECT",
    "GCS_BUCKET",
    "GCS_CLIENT_EMAIL",
    "GCS_PRIVATE_KEY",
    "GCS_PROJECT_ID",
    "GOOGLE_CLIENT_ID",
    "GOOGLE_CLIENT_SECRET",
    "LOG_LEVEL",
    "NODE_ENV",
    "UPSTASH_REDIS_HOST",
    "UPSTASH_REDIS_PASSWORD",
    "UPSTASH_REDIS_PORT"
  ],
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "inputs": ["$TURBO_DEFAULT$", ".env*"],
      "outputs": [".next/**", "!.next/cache/**", "dist/**"]
    },
    "lint": {
      "dependsOn": ["^lint"]
    },
    "format": {
      "dependsOn": ["^format"]
    },
    "typecheck": {
      "dependsOn": ["^typecheck"]
    },
    "dev": {
      "cache": false,
      "persistent": true
    }
  }
}
