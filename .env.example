NODE_ENV=development
LOG_LEVEL=info

DATABASE_URL=postgres://USER:PASSWORD@HOST:5432/DB_NAME
DATABASE_URL_DIRECT=postgres://USER:PASSWORD@HOST:5432/DB_NAME

BETTER_AUTH_SECRET=replace-with-a-random-32-plus-character-secret
BETTER_AUTH_URL=http://localhost:3000

GOOGLE_CLIENT_ID=replace-with-google-client-id
GOOGLE_CLIENT_SECRET=replace-with-google-client-secret
APP_ENCRYPTION_KEY=replace-with-a-random-32-plus-character-app-encryption-key

GCS_BUCKET=replace-with-private-gcs-bucket-name
GCS_PROJECT_ID=replace-with-google-cloud-project-id
GCS_CLIENT_EMAIL=replace-with-gcs-service-account-email
GCS_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"

AI_GATEWAY_API_KEY=replace-with-vercel-ai-gateway-api-key
LOGO_DOT_DEV_SECRET_KEY=replace-with-logo-dot-dev-secret-key
NEXT_PUBLIC_LOGO_DOT_DEV_PUBLIC_KEY=replace-with-logo-dot-dev-public-key
CURRENCYAPI_API_KEY=replace-with-currencyapi-key
CRON_SECRET=replace-with-cron-secret

UPSTASH_REDIS_HOST=example.upstash.io
UPSTASH_REDIS_PORT=6379
UPSTASH_REDIS_PASSWORD=replace-with-upstash-redis-password
