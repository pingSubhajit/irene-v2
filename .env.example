NODE_ENV=development
LOG_LEVEL=info

DATABASE_URL=postgres://USER:PASSWORD@HOST:5432/DB_NAME
DATABASE_URL_DIRECT=postgres://USER:PASSWORD@HOST:5432/DB_NAME

BETTER_AUTH_SECRET=replace-with-a-random-32-plus-character-secret
BETTER_AUTH_URL=http://localhost:3000

GOOGLE_CLIENT_ID=replace-with-google-client-id
GOOGLE_CLIENT_SECRET=replace-with-google-client-secret
ALLOWED_EMAILS=owner@example.com

UPSTASH_REDIS_HOST=example.upstash.io
UPSTASH_REDIS_PORT=6379
UPSTASH_REDIS_PASSWORD=replace-with-upstash-redis-password
