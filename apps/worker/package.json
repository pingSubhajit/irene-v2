{
  "name": "worker",
  "version": "0.0.1",
  "type": "module",
  "private": true,
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc --noEmit && mkdir -p dist && printf 'ok\\n' > dist/.build-stamp",
    "start": "tsx src/index.ts",
    "lint": "eslint src --ext .ts",
    "typecheck": "tsc --noEmit",
    "test": "tsx --test src/**/*.test.ts"
  },
  "dependencies": {
    "@workspace/ai": "workspace:*",
    "@workspace/config": "workspace:*",
    "@workspace/db": "workspace:*",
    "@workspace/integrations": "workspace:*",
    "@workspace/observability": "workspace:*",
    "@workspace/workflows": "workspace:*",
    "bullmq": "^5.71.0",
    "drizzle-orm": "^0.45.1",
    "html-to-text": "^9.0.5",
    "ioredis": "^5.9.3",
    "pdf-parse": "^2.4.5",
    "pg": "^8.20.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/node": "^25.1.0",
    "@workspace/eslint-config": "workspace:*",
    "@workspace/typescript-config": "workspace:*",
    "eslint": "^9.39.2",
    "typescript": "^5.9.3"
  }
}
